{
  "name": "nav-item",
  "version": "1.1.0",
  "author": "xiaokcoding",
  "description": "nav-item on Cloudflare Pages + Functions",
  "repository": "https://github.com/xiaokcoding/nav-item-cloudflare",
  "license": "MIT",
  "scripts": {
    "postinstall": "npm install --prefix web",
    "build": "npm install --prefix web && cd web && npm run build",
    "dev": "wrangler pages dev web/dist --compatibility-date=2025-12-08",
    "deploy": "wrangler pages deploy web/dist --compatibility-date=2025-12-08"
  },
  "dependencies": {
    "hono": "^4.6.7"
  },
  "devDependencies": {
    "wrangler": "^3.84.0"
  },
  "engines": {
    "node": ">=18"
  }
}